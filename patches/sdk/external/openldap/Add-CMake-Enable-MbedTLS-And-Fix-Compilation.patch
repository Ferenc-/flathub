diff --git a/external/linphone-sdk/external/openldap/libraries/libldap/tls_m.c b/external/linphone-sdk/external/openldap/libraries/libldap/tls_m.c
new file mode 100644
index 0000000000..258d643a39
--- /dev/null
+++ b/external/linphone-sdk/external/openldap/libraries/libldap/tls_m.c
@@ -0,0 +1,1059 @@
+/*
