+++ b/external/linphone-sdk/external/openldap/cmake/CheckFunctionsAndLibs.cmake
@@ -0,0 +1,312 @@
+############################################################################
+# CMakeLists.txt
+# Copyright (C) 2010-2021  Belledonne Communications, Grenoble France
+#
