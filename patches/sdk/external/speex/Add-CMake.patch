+		cb_search.c
+		exc_10_16_table.c
+		exc_10_32_table.c
+		exc_20_32_table.c
+		exc_5_256_table.c
+		exc_5_64_table.c
+		exc_8_128_table.c
+		filters.c
+		gain_table.c
+		gain_table_lbr.c
+		hexc_10_32_table.c
+		hexc_table.c
+		high_lsp_tables.c
+		lpc.c
+		lsp.c
+		lsp_tables_nb.c
+		ltp.c
+		modes.c
+		modes_wb.c
+		nb_celp.c
+		quant_lsp.c
+		sb_celp.c
+		speex.c
+		speex_callbacks.c
+		speex_header.c
+		stereo.c
+		vbr.c
+		vq.c
+		window.c
+	)
+
+	add_library(speex ${LIBSPEEX_SOURCE_FILES})
+	set_target_properties(speex PROPERTIES VERSION 6)
+	target_link_libraries(speex ${LIBS})
+	target_include_directories(speex PUBLIC
+		$<BUILD_INTERFACE:${PROJECT_SOURCE_DIR}/include>
+		$<BUILD_INTERFACE:${PROJECT_BINARY_DIR}>
