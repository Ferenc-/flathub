    Update CMakeLists.txt so that the project can be added as a subdirectory of linphone-sdk.
    
    Do not treat warnings as errors when building with gcc or clang.
    
    fix cross compilation issue with try_run

diff --git a/external/linphone-sdk/external/liboqs/.CMake/gcc_clang_intrinsics.cmake b/external/linphone-sdk/external/liboqs/.CMake/gcc_clang_intrinsics.cmake
index fd45d753..2f079da8 100644
--- a/external/linphone-sdk/external/liboqs/.CMake/gcc_clang_intrinsics.cmake
+++ b/external/linphone-sdk/external/liboqs/.CMake/gcc_clang_intrinsics.cmake
@@ -1,12 +1,13 @@
 # SPDX-License-Identifier: MIT
-
-try_run(RUN_RESULT COMPILE_RESULT
-        "${CMAKE_BINARY_DIR}" "${PROJECT_SOURCE_DIR}/.CMake/detect_gcc_clang_intrinsics.c"
-        COMPILE_DEFINITIONS ${OQS_OPT_FLAG}
-        COMPILE_OUTPUT_VARIABLE COMPILE_OUTPUT
-        RUN_OUTPUT_VARIABLE RUN_OUTPUT)
-if(NOT COMPILE_RESULT)
-     message(FATAL_ERROR "Could not compile .CMake/detect_gcc_clang_intrinsics.c" ${COMPILE_OUTPUT})
+if(NOT CMAKE_CROSSCOMPILING)
+	try_run(RUN_RESULT COMPILE_RESULT
+        	"${CMAKE_BINARY_DIR}" "${PROJECT_SOURCE_DIR}/.CMake/detect_gcc_clang_intrinsics.c"
+        	COMPILE_DEFINITIONS ${OQS_OPT_FLAG}
+        	COMPILE_OUTPUT_VARIABLE COMPILE_OUTPUT
+        	RUN_OUTPUT_VARIABLE RUN_OUTPUT)
+	if(NOT COMPILE_RESULT)
+     	message(FATAL_ERROR "Could not compile .CMake/detect_gcc_clang_intrinsics.c" ${COMPILE_OUTPUT})
+	endif()
 endif()
 if(NOT RUN_RESULT EQUAL 0)
 	if(CMAKE_CROSSCOMPILING)
